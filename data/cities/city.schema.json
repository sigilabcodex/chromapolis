{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://chromapolis.example/schema/city.schema.json",
  "title": "Chromapolis City Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "slug",
    "name",
    "country",
    "countryCode",
    "coordinates",
    "palette",
    "sources",
    "editorialSummary"
  ],
  "properties": {
    "slug": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "name": { "type": "string", "minLength": 1 },
    "country": { "type": "string", "minLength": 1 },
    "countryCode": { "type": "string", "pattern": "^[A-Z]{2}$" },
    "region": { "type": "string" },
    "coordinates": {
      "type": "object",
      "additionalProperties": false,
      "required": ["lat", "lon"],
      "properties": {
        "lat": { "type": "number", "minimum": -90, "maximum": 90 },
        "lon": { "type": "number", "minimum": -180, "maximum": 180 }
      }
    },
    "population": { "type": "integer", "minimum": 0 },
    "palette": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["hex", "name", "layer", "rationale", "confidence", "official", "prominence"],
        "properties": {
          "hex": { "type": "string", "pattern": "^#([0-9A-Fa-f]{6})$" },
          "name": { "type": "string", "minLength": 1 },
          "layer": {
            "type": "string",
            "enum": ["official", "historical", "natural", "architectural", "cultural", "symbolic", "editorial"]
          },
          "rationale": { "type": "string", "minLength": 1 },
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "official": { "type": "boolean" },
          "prominence": { "type": "number", "minimum": 0, "maximum": 1 }
        }
      }
    },
    "sources": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["title", "url", "publisher", "sourceType"],
        "properties": {
          "title": { "type": "string", "minLength": 1 },
          "url": { "type": "string", "format": "uri" },
          "publisher": { "type": "string", "minLength": 1 },
          "sourceType": {
            "type": "string",
            "enum": ["government", "academic", "media", "community", "editorial", "other"]
          },
          "note": { "type": "string" }
        }
      }
    },
    "notes": { "type": "string" },
    "editorialSummary": { "type": "string", "minLength": 1 }
  }
}
